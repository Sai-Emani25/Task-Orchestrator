{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "A task or event scheduled by the orchestrator",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who owns this task" },
        "title": { "type": "string", "description": "The title of the task or event" },
        "time": { "type": "string", "description": "ISO 8601 format of the task time" },
        "priority": { "type": "string", "enum": ["High", "Medium", "Low"] },
        "status": { "type": "string", "enum": ["Pending", "In Progress", "Completed"] },
        "subTasks": { 
          "type": "array", 
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "status": { "type": "string", "enum": ["Pending", "In Progress", "Completed"] }
            }
          }
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "description": "IDs of tasks that must be completed before this task can start"
        },
        "createdAt": { "type": "object", "description": "Firestore server timestamp" },
        "updatedAt": { "type": "object", "description": "Firestore server timestamp" }
      },
      "required": ["userId", "title", "priority", "status"]
    },
    "Note": {
      "title": "Note",
      "description": "A note stored by the orchestrator",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who owns this note" },
        "content": { "type": "string", "description": "The content of the note" },
        "createdAt": { "type": "object", "description": "Firestore server timestamp" }
      },
      "required": ["userId", "content"]
    },
    "Interaction": {
      "title": "Interaction",
      "description": "A log of an interaction with the orchestrator",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who had this interaction" },
        "query": { "type": "string" },
        "priority": { "type": "string" },
        "reasoning": { "type": "string" },
        "response": { "type": "string" },
        "metadata": { "type": "string" },
        "createdAt": { "type": "object" }
      },
      "required": ["userId", "query", "response"]
    }
  },
  "firestore": {
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "User's scheduled tasks"
    },
    "/notes/{noteId}": {
      "schema": "Note",
      "description": "User's stored notes"
    },
    "/interactions/{interactionId}": {
      "schema": "Interaction",
      "description": "User's interaction history"
    }
  }
}
